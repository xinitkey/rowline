# Environment variables for maximum server performance on Ubuntu
# Copy this to .env file and load with: export $(cat .env | xargs)

# Uvicorn workers (processes)
# Set to number of CPU cores for maximum parallelism
UVICORN_WORKERS=8

# Thread pool size (per worker)
# Higher values for I/O bound tasks
MAX_WORKERS=128

# Process pool for CPU-bound tasks
# Set to CPU cores for CPU-intensive operations
PROCESS_POOL_SIZE=16

# Maximum concurrent operations
# Balance between performance and stability
MAX_CONCURRENT_OPERATIONS=64

# Optional: Gunicorn configuration (if using gunicorn instead of uvicorn)
# GUNICORN_WORKERS=16
# GUNICORN_WORKER_CLASS=uvicorn.workers.UvicornWorker